{
  "name": "@ttab/elephant-tt-api",
  "private": false,
  "license": "MIT",
  "version": "0.4.2",
  "type": "module",
  "exports": {
    "./baboon": {
      "import": {
        "types": "./dist/baboon/index.d.mts",
        "default": "./dist/baboon/index.mjs"
      },
      "require": {
        "types": "./dist/baboon/index.d.cts",
        "default": "./dist/baboon/index.cjs"
      }
    },
    "./eidos": {
      "import": {
        "types": "./dist/eidos/index.d.mts",
        "default": "./dist/eidos/index.mjs"
      },
      "require": {
        "types": "./dist/eidos/index.d.cts",
        "default": "./dist/eidos/index.cjs"
      }
    },
    "./everysport": {
      "import": {
        "types": "./dist/everysport/index.d.mts",
        "default": "./dist/everysport/index.mjs"
      },
      "require": {
        "types": "./dist/everysport/index.d.cts",
        "default": "./dist/everysport/index.cjs"
      }
    },
    "./genai": {
      "import": {
        "types": "./dist/genai/index.d.mts",
        "default": "./dist/genai/index.mjs"
      },
      "require": {
        "types": "./dist/genai/index.d.cts",
        "default": "./dist/genai/index.cjs"
      }
    },
    "./ntb": {
      "import": {
        "types": "./dist/ntb/index.d.mts",
        "default": "./dist/ntb/index.mjs"
      },
      "require": {
        "types": "./dist/ntb/index.d.cts",
        "default": "./dist/ntb/index.cjs"
      }
    },
    "./wires": {
      "import": {
        "types": "./dist/wires/index.d.mts",
        "default": "./dist/wires/index.mjs"
      },
      "require": {
        "types": "./dist/wires/index.d.cts",
        "default": "./dist/wires/index.cjs"
      }
    },
    "./hub": {
      "import": {
        "types": "./dist/hub/index.d.mts",
        "default": "./dist/hub/index.mjs"
      },
      "require": {
        "types": "./dist/hub/index.d.cts",
        "default": "./dist/hub/index.cjs"
      }
    },
    "./reportingstream": {
      "import": {
        "types": "./dist/reportingstream/index.d.mts",
        "default": "./dist/reportingstream/index.mjs"
      },
      "require": {
        "types": "./dist/reportingstream/index.d.cts",
        "default": "./dist/reportingstream/index.cjs"
      }
    },
    "./intelligence": {
      "import": {
        "types": "./dist/intelligence/index.d.mts",
        "default": "./dist/intelligence/index.mjs"
      },
      "require": {
        "types": "./dist/intelligence/index.d.cts",
        "default": "./dist/intelligence/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/ttab"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttab/elephant-tt-api-npm.git"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:baboon": "tsdown ./src/baboon/index.ts --format cjs,esm --dts --outDir ./dist/baboon",
    "build:eidos": "tsdown ./src/eidos/index.ts --format cjs,esm --dts --outDir ./dist/eidos",
    "build:everysport": "tsdown ./src/everysport/index.ts --format cjs,esm --dts --outDir ./dist/everysport",
    "build:genai": "tsdown ./src/genai/index.ts --format cjs,esm --dts --outDir ./dist/genai",
    "build:ntb": "tsdown ./src/ntb/index.ts --format cjs,esm --dts --outDir ./dist/ntb",
    "build:wires": "tsdown ./src/wires/index.ts --format cjs,esm --dts --outDir ./dist/wires",
    "build:hub": "tsdown ./src/hub/index.ts --format cjs,esm --dts --outDir ./dist/hub",
    "build:reportingstream": "tsdown ./src/reportingstream/index.ts --format cjs,esm --dts --outDir ./dist/reportingstream",
    "build:intelligence": "tsdown ./src/intelligence/index.ts --format cjs,esm --dts --outDir ./dist/intelligence",
    "build": "npm run build:baboon && npm run build:eidos && npm run build:everysport && npm run build:genai && npm run build:ntb && npm run build:wires && npm run build:hub && npm run build:reportingstream && npm run build:intelligence",
    "update": "bash .github/workflows/update.sh",
    "prepublish": "npm run build"
  },
  "author": "",
  "description": "",
  "devDependencies": {
    "@protobuf-ts/plugin": "^2.11.1",
    "tsdown": "^0.20.3"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1"
  }
